{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Event",
  "description": "A record of a system-level event in the commandcenter workflow.",
  "type": "object",
  "required": ["event_type", "timestamp", "source"],
  "properties": {
    "event_type": {
      "type": "string",
      "enum": [
        "work.accepted",
        "work.rejected",
        "work.completed",
        "work.failed",
        "work.cancelled",
        "builder.assigned",
        "builder.unassigned",
        "builder.completed",
        "builder.failed",
        "promotion.held",
        "promotion.rejected",
        "scheduler.decision",
        "scheduler.acknowledged",
        "scheduler.failed",
        "scheduler.rejected",
        "capacity.observed",
        "capacity.estimated",
        "experiment.plan",
        "experiment.started",
        "experiment.completed",
        "experiment.failed",
        "experiment.cancelled",
        "finding.generated",
        "finding.verified",
        "finding.rejected",
        "finding.archived",
        "policy.applied",
        "policy.rejected",
        "policy.overridden",
        "policy.updated",
        "capability.registered",
        "capability.updated",
        "capability.removed",
        "association.created",
        "association.updated",
        "association.removed",
        "coverage.updated",
        "coverage.rejected",
        "coverage.verified",
        "experiment.result",
        "experiment.candidate",
        "experiment.scheduled",
        "experiment.terminated",
        "idle.observed",
        "idle.ended"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "node_id": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}