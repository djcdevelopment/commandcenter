{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capacity Observation",
  "description": "Observation of physical resource usage and model residency state during a run.",
  "type": "object",
  "properties": {
    "contract_version": { "type": "string", "const": "capacity-observation.v1" },
    "run_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "observed": {
      "type": "object",
      "properties": {
        "physical": {
          "type": "object",
          "properties": {
            "gpu_temp_c_peak": { "type": ["number", "null"] },
            "gpu_temp_c_sustained_avg": { "type": ["number", "null"] },
            "power_w_avg": { "type": ["number", "null"] },
            "power_w_peak": { "type": ["number", "null"] },
            "fan_rpm_avg": { "type": ["number", "null"] },
            "clock_mhz_avg": { "type": ["number", "null"] },
            "model_residency": {
              "description": "DERIVED classification — computed by projection from the raw model_* fields; producers/collectors must never set this directly.",
              "type": "string",
              "enum": [null, "cold_load", "warm_resident", "evicted_mid_run"]
            },
            "model_loaded_at_start": { "type": ["boolean", "null"] },
            "model_load_count": { "type": ["integer", "null"] },
            "model_unload_count": { "type": ["integer", "null"] },
            "model_load_s": { "type": ["number", "null"] }
          },
          "required": [
            "gpu_temp_c_peak",
            "gpu_temp_c_sustained_avg",
            "power_w_avg",
            "power_w_peak",
            "fan_rpm_avg",
            "clock_mhz_avg",
            "model_residency",
            "model_loaded_at_start",
            "model_load_count",
            "model_unload_count",
            "model_load_s"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["contract_version", "run_id", "timestamp", "observed"],
  "additionalProperties": false
}